.env.example# ----------------------------------------------------------------------
# Variáveis de ambiente do frontend (copie para .env e preencha)
# ----------------------------------------------------------------------

# Client ID do OAuth do Google (MESMO usado no backend GOOGLE_CLIENT_ID).
# Crie um "OAuth Client ID" do tipo "Web application" no Google Cloud Console
# e adicione http://localhost:5173 em "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# URL base da API do backend.
VITE_API_URL=http://localhost:8080
